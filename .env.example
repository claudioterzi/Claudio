# Variabili d'ambiente richieste da SDQ-1
# Copia questo file come .env e inserisci le chiavi reali
# NON committare mai .env — è già in .gitignore

# --- Provider LLM (almeno uno obbligatorio) ---

# Anthropic (Claude) — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini — https://aistudio.google.com/apikey
GOOGLE_API_KEY=AIza...

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# DeepSeek — https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-...

# Perplexity — https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-...

# --- Provider locale (opzionale) ---
# Ollama non richiede API key — installare da https://ollama.ai
# Il modello default è llama3.2: ollama pull llama3.2

# --- Configurazione opzionale ---
# SDQ1_CONFIG_PATH=/path/to/custom/sdq1.yaml
# SDQ1_LOG_LEVEL=INFO
