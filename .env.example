# Esempio di configurazione — copia in `.env` e riempi con i valori veri.
# Il file `.env` NON viene committato (è in .gitignore). I segreti non vanno
# mai scritti in chat, documenti o messaggi condivisi.

# --- Telegram (bot Raffaello / note SDQ-1) ---
# Token del bot da @BotFather. Se è mai finito in una chat/immagine, rigeneralo.
TELEGRAM_BOT_TOKEN=metti_qui_il_token
# Id della chat di destinazione (scoprilo con getUpdates dopo aver scritto al bot).
TELEGRAM_CHAT_ID=metti_qui_il_chat_id

# --- LLM providers SDQ-1 (opzionali, fallback automatico a stub) ---
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
