{
  "carte": [
    {
      "id": 1,
      "nome": "La Scintilla",
      "simbolo": "✦",
      "ciclo": "Origine",
      "luce": {
        "nord": "vocazione che si risveglia",
        "est": "primo gesto creativo",
        "sud": "entusiasmo nascente",
        "ovest": "ricordo di ciò che ti accende"
      },
      "ombra": {
        "nord": "potenziale represso",
        "est": "impulso che brucia invano",
        "sud": "eccitazione senza radici",
        "ovest": "rimpianto del fuoco mai acceso"
      }
    },
    {
      "id": 2,
      "nome": "L'Orizzonte",
      "simbolo": "─",
      "ciclo": "Origine",
      "luce": {
        "nord": "visione che viene da lontano",
        "est": "meta che chiama in avanti",
        "sud": "speranza condivisa",
        "ovest": "prospettiva conquistata"
      },
      "ombra": {
        "nord": "miraggio mai raggiunto",
        "est": "fuga perpetua in avanti",
